# macOS Finder metadata
.DS_Store

# Internal QA artifacts — kept locally, not published. Working notes
# (bug triage, manual-test walkthroughs, static-analysis dumps) live
# under qa/ so the repo root stays clean. The whole folder is ignored;
# un-ignore specific files inside if you ever want public bug
# transparency.
.gstack/
qa/

# Wrangler local state (the published wrangler.toml is checked in)
worker/.wrangler/
worker/wrangler.local.toml
worker/node_modules/

# Web Store submission build artifacts. Generated by zip; the contents
# are derivable from tracked files, so we don't keep the .zip in git.
dist/

# Node deps + Playwright caches. The smoke test config + spec are tracked
# under playwright.config.js and tests/, but installed packages and test
# output artifacts are not.
node_modules/
package-lock.json
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/
